# Copy to .env: cp .env.example .env

# OpenAI API key for AI chat (get yours at https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# Database (optional — Docker Compose sets this automatically)
# For local dev without Docker: start Postgres, then uncomment:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/litigant_portal

# Domain for production Caddy (auto-HTTPS via Let's Encrypt)
# DOMAIN=yourdomain.com

# Django allowed hosts — must match DOMAIN (comma-separated, no spaces) or Django returns 400 for all requests
# ALLOWED_HOSTS=portal.example.com