##############################################################################
# LLM Provider Credentials
##############################################################################

# You can add credentials for any LLM provider here.
# OpenAI is used by default.
OPENAI_API_KEY=your-openai-api-key-here

##############################################################################
# Production Environment Variables
##############################################################################

# Django secret key
# SECRET_KEY=generate-a-long-random-string

# Prod mode + environment label (qa / prod)
# DEBUG=false
# DEPLOYMENT_ENV=prod

# Django allowed hosts — must include app domain (comma-separated, no spaces)
# ALLOWED_HOSTS=yourdomain.com

# Chat model (LiteLLM format)
# CHAT_MODEL=openai/gpt-4o-mini

# PostgreSQL connection details
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=litigant_portal

# Redis connection details
# REDIS_URL=redis://localhost:6379/0

# S3 object storage (static + public/private media)
# USE_S3=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_STORAGE_PUBLIC_BUCKET_NAME=
# AWS_STORAGE_PRIVATE_BUCKET_NAME=
# AWS_S3_CUSTOM_DOMAIN=storage.litigantportal.com
